{
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/fan-dashboard", "destination": "/fan-dashboard.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" },
    { "source": "/how-it-works", "destination": "/how-it-works.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/booking-confirmed", "destination": "/booking-confirmed.html" },
    { "source": "/confirm", "destination": "/confirm.html" },
    { "source": "/creator/:handle", "destination": "/creator.html" },
    { "source": "/room", "destination": "/room.html" },
    { "source": "/room/:path", "destination": "/room.html" },
    { "source": "/onboard-complete", "destination": "/onboard-complete.html" },
    { "source": "/onboard-refresh", "destination": "/onboard-refresh.html" },
    { "source": "/creator-setup", "destination": "/creator-setup.html" },
    { "source": "/featured-apply", "destination": "/featured-apply.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
